{
  "name": "rag-research-workbook",
  "version": "1.2.0",
  "description": "RAG Research Workbook — AI-powered research assistant",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.ragresearchworkbook.app",
    "productName": "RAG Research Workbook",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "mammoth": "^1.7.0",
    "officeparser": "^4.1.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  }
}
